APP_NAME="Midnight Travel Invoices"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE="database/database.sqlite"

SESSION_DRIVER=file
SESSION_LIFETIME=120

# Change in production! Used by one-time setup/seed URL (?token=...). Use a long random value.
SETUP_SECRET=midnight-travel-setup-change-me
