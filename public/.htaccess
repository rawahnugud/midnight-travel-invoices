<IfModule mod_rewrite.c>
    RewriteEngine On

    # Optional: force HTTPS in production (uncomment when using SSL)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remove trailing slash (e.g. /dashboard/ -> /dashboard) for clean URLs
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # If app is in a subdirectory, uncomment and set the path (e.g. /invoices):
    # RewriteBase /invoices

    # Send all other requests to index.php (no index.php in browser URL)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
